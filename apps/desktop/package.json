{
  "name": "@easycode/desktop",
  "productName": "easycode",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "cd ../.. && bun run build && cd apps/desktop && bun run build && EASYCODE_DESKTOP_SIDECAR_PATH=../../dist/easycode node scripts/run-electron.mjs",
    "dev:insecure": "cd ../.. && bun run build && cd apps/desktop && bun run build && EASYCODE_DESKTOP_SIDECAR_PATH=../../dist/easycode EASYCODE_DESKTOP_SIDECAR_INSECURE=1 node scripts/run-electron.mjs",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node scripts/bundle-preload.mjs && vite build",
    "build:icons": "node scripts/make-icon-source.mjs && node scripts/make-mac-icon.mjs",
    "electron": "bun run build && node scripts/run-electron.mjs",
    "package": "bun run build:icons && electron-builder"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "build": {
    "appId": "dev.easycode.desktop",
    "productName": "easycode",
    "icon": "build/icon.png",
    "mac": {
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleDisplayName": "easycode",
        "CFBundleName": "easycode"
      }
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "build/icon.png",
      "build/icon.icns"
    ],
    "extraResources": [
      {
        "from": "../../dist",
        "to": "sidecar",
        "filter": [
          "easycode*"
        ]
      }
    ]
  }
}
