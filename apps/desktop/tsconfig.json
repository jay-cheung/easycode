{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["electron", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.cts"]
}
