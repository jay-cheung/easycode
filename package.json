{
  "name": "easycode",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts build --provider deepseek --logger -k",
    "dev:openai": "bun run src/cli.ts build --provider openai --logger",
    "dev:plan": "bun run src/cli.ts plan --provider deepseek --logger",
    "mcp:test:server": "bun run dev/mcp/test-server.ts",
    "gate": "bun run dev/quality/quality-gate.ts",
    "test": "bun test",
    "test:real": "EASYCODE_TEST_PROVIDER=deepseek bun test test/integration/real-provider.test.ts",
    "eval:real": "bun run dev/quality/eval.ts --provider ${EASYCODE_TEST_PROVIDER:-deepseek}",
    "apix:real": "bun run apix:eval --provider ${EASYCODE_TEST_PROVIDER:-deepseek} --table",
    "eval": "bun run dev/quality/eval.ts",
    "apix:eval": "bun run dev/quality/apix.ts",
    "apix:fixtures": "bun run dev/quality/apix/generate-fixtures.ts",
    "cache:bench": "bun run dev/quality/cache-benchmark.ts",
    "provider:gate": "bun run dev/quality/provider-gate.ts",
    "typecheck": "bunx tsc --noEmit",
    "verify:v1": "bun run dev/quality/quality-gate.ts --preset dev",
    "verify:full": "bun run dev/quality/quality-gate.ts --preset full",
    "verify:provider": "bun run dev/quality/quality-gate.ts --preset provider",
    "build": "bun build --compile ./src/cli.ts --outfile dist/easycode",
    "build:linux-x64": "bun build --compile --target bun-linux-x64 ./src/cli.ts --outfile dist/easycode-linux-x64",
    "build:linux-arm64": "bun build --compile --target bun-linux-arm64 ./src/cli.ts --outfile dist/easycode-linux-arm64",
    "build:darwin-x64": "bun build --compile --target bun-darwin-x64 ./src/cli.ts --outfile dist/easycode-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target bun-darwin-arm64 ./src/cli.ts --outfile dist/easycode-darwin-arm64",
    "build:win-x64": "bun build --compile --target bun-windows-x64 ./src/cli.ts --outfile dist/easycode-win-x64.exe",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^5.8.2"
  }
}
