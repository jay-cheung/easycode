{
  "name": "easycode",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts build --provider deepseek --logger",
    "dev:openai": "bun run src/cli.ts build --provider openai --logger",
    "dev:plan": "bun run src/cli.ts plan --provider deepseek --logger",
    "test": "bun test",
    "test:real": "EASYCODE_TEST_PROVIDER=deepseek bun test test/integration/real-provider.test.ts",
    "eval:real": "bun run eval --provider ${EASYCODE_TEST_PROVIDER:-deepseek}",
    "apix:real": "bun run apix:eval --provider ${EASYCODE_TEST_PROVIDER:-deepseek} --table",
    "eval": "bun run src/eval.ts",
    "apix:eval": "bun run src/evals/apix.ts",
    "apix:fixtures": "bun run evals/apix/generate-fixtures.ts",
    "cache:bench": "bun run src/cache-benchmark.ts",
    "typecheck": "bunx tsc --noEmit",
    "verify:v1": "bun run typecheck && bun test && bun run eval --provider fake && bun run cache:bench -- --provider simulated --suite real --quiet",
    "build": "bun build --compile ./src/cli.ts --outfile dist/easycode",
    "build:linux-x64": "bun build --compile --target bun-linux-x64 ./src/cli.ts --outfile dist/easycode-linux-x64",
    "build:linux-arm64": "bun build --compile --target bun-linux-arm64 ./src/cli.ts --outfile dist/easycode-linux-arm64",
    "build:darwin-x64": "bun build --compile --target bun-darwin-x64 ./src/cli.ts --outfile dist/easycode-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target bun-darwin-arm64 ./src/cli.ts --outfile dist/easycode-darwin-arm64",
    "build:win-x64": "bun build --compile --target bun-windows-x64 ./src/cli.ts --outfile dist/easycode-win-x64.exe",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^5.8.2"
  }
}
